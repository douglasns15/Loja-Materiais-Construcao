// =============================================================================
// NexoLoja - Schema do Banco de Dados (Supabase / PostgreSQL)
// =============================================================================
// Arquitetura: Multi-Tenant, Modular e Offline-First
//
// Princípios seguidos (conforme CLAUDE.md):
//  - Multi-tenancy estrito: toda tabela de dados possui `tenantId` (UUID da loja)
//  - Tipos leves: SmallInt para status/enums, VarChar com limite estrito
//  - Proibido salvar BLOBs: apenas URLs de mídia (Cloudflare R2)
//  - Campos de sincronização offline: `id` UUID gerado no cliente, `syncStatus`
//  - Módulos ativáveis: tabela `TenantModule` controla quais módulos cada loja usa
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")  // Pooler 6543 (pgbouncer) — runtime da aplicação
  directUrl = env("DIRECT_URL")    // Porta direta 5432 — usada pelas migrations (migrate/diff)
}

// =============================================================================
// ENUMS
// =============================================================================

/// Status de sincronização para suporte Offline-First (IndexedDB → Supabase)
enum SyncStatus {
  PENDING   // Criado localmente, aguardando envio ao servidor
  SYNCED    // Confirmado no servidor
  CONFLICT  // Conflito detectado durante sincronização
}

/// Tipo de movimentação financeira
enum TransactionType {
  INCOME    // Entrada
  EXPENSE   // Saída
}

/// Status de um pedido/venda
enum OrderStatus {
  DRAFT      // Rascunho (aberto no caixa offline)
  CONFIRMED  // Confirmado
  INVOICED   // Faturado / NF emitida
  CANCELLED  // Cancelado (estorno dentro do caixa aberto)
  RETURNED   // Devolvido (estorno de venda de caixa já fechado — saída no caixa de hoje)
}

/// Natureza de uma movimentação de caixa que não é uma venda (CashMovement).
enum CashMovementKind {
  RETURN      // Devolução de venda (saída de dinheiro)
  WITHDRAWAL  // Sangria — retirada de dinheiro do caixa (saída)
  SUPPLY      // Suprimento — reforço de troco (entrada)
  EXPENSE     // Despesa paga pelo caixa (saída)
}

/// Tipo de unidade de medida — relevante para módulo Material de Construção
enum UnitType {
  UNIT       // Unidade (un)
  METER      // Metro linear (m)
  SQUARE_METER // Metro quadrado (m²)
  CUBIC_METER  // Metro cúbico (m³)
  KILOGRAM   // Quilograma (kg)
  LITER      // Litro (l)
  THOUSAND   // Milheiro (mil) — ex: tijolos
  BAG        // Saco (sc) — ex: cimento
  ROLL       // Rolo — ex: manta, tela
}

/// Papel do usuário dentro de um tenant
enum UserRole {
  OWNER      // Dono da loja (acesso total)
  MANAGER    // Gerente
  CASHIER    // Operador de caixa
  STOCK      // Responsável de estoque
}

/// Status de entrega (ADR-002)
enum DeliveryStatus {
  PENDING    // Pendente
  IN_ROUTE   // Em rota
  DELIVERED  // Entregue
  CANCELLED  // Cancelado
}

// =============================================================================
// MÓDULO CORE — Tenants (Lojas) e Usuários
// =============================================================================

/// Representa uma loja/empresa (tenant). Raiz do multi-tenancy.
model Tenant {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(120)
  slug        String   @unique @db.VarChar(60)  // Identificador único amigável (ex: "loja-do-ze")
  cnpj        String?  @unique @db.VarChar(18)
  phone       String?  @db.VarChar(20)
  logoUrl     String?  @db.VarChar(500)          // URL no Cloudflare R2 — nunca BLOB
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  users       User[]
  modules     TenantModule[]
  products    Product[]
  categories  Category[]
  customers   Customer[]
  suppliers   Supplier[]
  orders      Order[]
  payments    Payment[]
  cashSessions CashSession[]
  cashMovements CashMovement[]
  stockMovements StockMovement[]
  deliveries  Delivery[]
  auditEvents AuditEvent[]

  @@map("tenants")
}

/// Módulos ativáveis por tenant (ex: "CONSTRUCTION_MATERIALS", "FOOD", "CLOTHING")
model TenantModule {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  moduleKey String   @db.VarChar(60)  // Ex: "CONSTRUCTION_MATERIALS"
  isActive  Boolean  @default(true)
  config    Json?                      // Configurações específicas do módulo (JSON leve)
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleKey])
  @@map("tenant_modules")
}

/// Usuário do sistema. Pertence a um único tenant.
/// ADR-005: as credenciais são propriedade do Supabase Auth (auth.users), não desta tabela.
/// `id` é fornecido pela aplicação e DEVE ser igual ao `auth.users.id` do Supabase Auth.
/// O vínculo formal (FK cross-schema para auth.users) será configurado na Fase 2 (Auth/RLS).
model User {
  id           String    @id @db.Uuid       // = Supabase Auth user id (auth.users.id)
  tenantId     String    @db.Uuid
  name         String    @db.VarChar(100)
  email        String    @db.VarChar(150)
  phone        String?   @db.VarChar(20)     // Telefone pessoal do usuário (opcional; só dígitos)
  role         UserRole  @default(CASHIER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders       Order[]
  cashSessions CashSession[]

  @@unique([tenantId, email])
  @@map("users")
}

/// Super Usuário (fabricante) — identidade de PLATAFORMA, acima de qualquer loja (ADR-009).
/// NÃO pertence a um tenant (sem `tenantId`/FK): é cross-tenant. `id` = `auth.users.id`
/// (Supabase Auth), como em `User`. O acesso a várias lojas é feito por rotas `/platform/*`
/// dedicadas (API dona do banco), nunca relaxando o RLS. RLS ligado sem política de cliente
/// (só a API-dono lê); o access token hook (supabase_auth_admin) lê esta tabela para injetar
/// o claim `is_platform_admin` no JWT — atalho de UI; a autorização confia na tabela.
model PlatformAdmin {
  id        String   @id @db.Uuid       // = Supabase Auth user id (auth.users.id)
  email     String   @unique @db.VarChar(150)
  name      String   @db.VarChar(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platform_admins")
}

// =============================================================================
// MÓDULO CORE — Catálogo de Produtos
// =============================================================================

/// Categoria de produto. Hierarquia simples (pai/filho).
model Category {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  parentId  String?   @db.Uuid          // Subcategoria (opcional)
  name      String    @db.VarChar(80)
  isActive  Boolean   @default(true)
  deletedAt DateTime?                   // Soft-delete (ADR-004)
  createdAt DateTime  @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent    Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]

  @@unique([tenantId, name, parentId])
  @@map("categories")
}

/// Produto do catálogo. Suporta unidades especiais do módulo Material de Construção.
model Product {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  categoryId      String?   @db.Uuid
  sku             String    @db.VarChar(60)   // Código interno ou código de barras
  name            String    @db.VarChar(150)
  description     String?   @db.VarChar(500)
  imageUrl        String?   @db.VarChar(500)  // URL no Cloudflare R2 — nunca BLOB
  unit            UnitType  @default(UNIT)
  /// Fator de conversão para módulo Material de Construção
  /// Ex: 1 milheiro = 1000 unidades → conversionFactor = 1000
  conversionFactor Decimal? @db.Decimal(10, 4)
  costPrice       Decimal   @db.Decimal(12, 4)
  salePrice       Decimal   @db.Decimal(12, 4)
  stockQty        Decimal   @default(0) @db.Decimal(12, 4)
  minStockQty     Decimal   @default(0) @db.Decimal(12, 4)
  isActive        Boolean   @default(true)
  deletedAt       DateTime?                   // Soft-delete (ADR-004)
  /// Peso em kg — usado para cálculo de frete pesado (módulo Material de Construção)
  weightKg        Decimal?  @db.Decimal(8, 3)
  // Campos de sincronização offline
  syncStatus      SyncStatus @default(SYNCED)
  updatedAt       DateTime   @updatedAt
  createdAt       DateTime   @default(now())

  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        Category?  @relation(fields: [categoryId], references: [id])
  orderItems      OrderItem[]
  stockMovements  StockMovement[]

  @@unique([tenantId, sku])
  @@index([tenantId, name])
  @@map("products")
}

// =============================================================================
// MÓDULO CORE — Clientes e Fornecedores
// =============================================================================

/// Cliente da loja.
model Customer {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  name        String    @db.VarChar(120)
  cpfCnpj     String?   @db.VarChar(18)
  phone       String?   @db.VarChar(20)
  email       String?   @db.VarChar(150)
  address     String?   @db.VarChar(300)
  notes       String?   @db.VarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?                   // Soft-delete (ADR-004)
  // Campos de sincronização offline
  syncStatus  SyncStatus @default(SYNCED)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders      Order[]
  deliveries  Delivery[]

  @@unique([tenantId, cpfCnpj])
  @@index([tenantId, name])
  @@map("customers")
}

/// Fornecedor de produtos.
model Supplier {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  name        String    @db.VarChar(120)
  cnpj        String?   @db.VarChar(18)
  phone       String?   @db.VarChar(20)
  email       String?   @db.VarChar(150)
  address     String?   @db.VarChar(300)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?                   // Soft-delete (ADR-004)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@unique([tenantId, cnpj])
  @@map("suppliers")
}

// =============================================================================
// MÓDULO CORE — Vendas (PDV / Caixa)
// =============================================================================

/// Sessão de caixa. Controla abertura/fechamento e totais do operador.
model CashSession {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  userId        String    @db.Uuid
  openedAt      DateTime  @default(now())
  closedAt      DateTime?
  openingAmount Decimal   @db.Decimal(12, 2)  // Valor de abertura do caixa
  closingAmount Decimal?  @db.Decimal(12, 2)  // Valor de fechamento informado
  expectedAmount Decimal? @db.Decimal(12, 2)  // Valor calculado pelo sistema
  notes         String?   @db.VarChar(500)
  // Campos de sincronização offline
  syncStatus    SyncStatus @default(SYNCED)

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id])
  orders        Order[]
  movements     CashMovement[]

  @@index([tenantId, openedAt])
  @@map("cash_sessions")
}

/// Pedido / Venda. Criado no caixa (pode ser offline).
model Order {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @db.Uuid
  cashSessionId  String?     @db.Uuid
  userId         String      @db.Uuid       // Operador que realizou a venda
  customerId     String?     @db.Uuid
  status         OrderStatus @default(DRAFT)
  subtotal       Decimal     @db.Decimal(12, 2)
  discountAmount Decimal     @default(0) @db.Decimal(12, 2)
  freightAmount  Decimal     @default(0) @db.Decimal(12, 2)  // Frete pesado (módulo Material de Construção)
  total          Decimal     @db.Decimal(12, 2)
  notes          String?     @db.VarChar(500)
  // Campos de sincronização offline
  syncStatus     SyncStatus  @default(PENDING)  // Vendas nascem como PENDING no caixa offline
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashSession    CashSession? @relation(fields: [cashSessionId], references: [id])
  user           User        @relation(fields: [userId], references: [id])
  customer       Customer?   @relation(fields: [customerId], references: [id])
  items          OrderItem[]
  payments       Payment[]
  delivery       Delivery?

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@map("orders")
}

/// Item de um pedido.
model OrderItem {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @db.Uuid
  productId   String   @db.Uuid
  productName String   @db.VarChar(150)  // Snapshot do nome no momento da venda
  unit        UnitType                   // Snapshot da unidade no momento da venda
  quantity    Decimal  @db.Decimal(12, 4)
  unitPrice   Decimal  @db.Decimal(12, 4)
  discount    Decimal  @default(0) @db.Decimal(12, 4)
  total       Decimal  @db.Decimal(12, 2)

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

/// Pagamento de um pedido. Um pedido pode ter múltiplos pagamentos (ex: dinheiro + cartão).
/// ADR-003: tenantId denormalizado para multi-tenancy estrito e RLS
model Payment {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid          // Denormalizado para isolamento multi-tenant (ADR-003)
  orderId   String   @db.Uuid
  method    String   @db.VarChar(30)   // Ex: "CASH", "CREDIT_CARD", "PIX", "BOLETO"
  amount    Decimal  @db.Decimal(12, 2)
  paidAt    DateTime @default(now())
  reference String?  @db.VarChar(100)  // NSU, código de transação, etc.

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderId])
  @@map("payments")
}

/// Movimentação de dinheiro no caixa que NÃO é uma venda: devolução, sangria,
/// suprimento e despesa avulsa. Entra no cálculo do valor esperado do caixa
/// (INCOME soma, EXPENSE subtrai), permitindo lançar a saída de uma devolução
/// no caixa de HOJE sem tocar no caixa original já fechado. `relatedOrderId`
/// referencia a venda de origem (devolução) — referência solta, no estilo de
/// AuditEvent (sem FK), pois a venda pode pertencer a outra sessão.
model CashMovement {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @db.Uuid          // Denormalizado para isolamento multi-tenant (ADR-003)
  cashSessionId  String           @db.Uuid
  userId         String           @db.Uuid          // Operador que lançou a movimentação
  type           TransactionType                    // INCOME soma / EXPENSE subtrai do esperado
  kind           CashMovementKind
  amount         Decimal          @db.Decimal(12, 2)
  reason         String?          @db.VarChar(300)
  relatedOrderId String?          @db.Uuid          // Venda de origem (devolução)
  // Campos de sincronização offline
  syncStatus     SyncStatus       @default(SYNCED)
  createdAt      DateTime         @default(now())

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashSession    CashSession      @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)

  @@index([tenantId, cashSessionId])
  @@map("cash_movements")
}

// =============================================================================
// MÓDULO MATERIAL DE CONSTRUÇÃO — Entrega Pesada
// =============================================================================

/// Entrega de pedido. Ativado pelo módulo "CONSTRUCTION_MATERIALS".
/// Suporta agendamento e controle de frete pesado.
/// ADR-002: status migrado de Int para enum DeliveryStatus
model Delivery {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @db.Uuid
  orderId        String         @unique @db.Uuid
  customerId     String         @db.Uuid
  scheduledAt    DateTime?                      // Data/hora agendada para entrega
  deliveredAt    DateTime?                      // Data/hora efetiva da entrega
  address        String         @db.VarChar(300)
  status         DeliveryStatus @default(PENDING)  // ADR-002: enum para type-safety
  driverName     String?        @db.VarChar(100)
  vehiclePlate   String?        @db.VarChar(10)
  totalWeightKg  Decimal?       @db.Decimal(10, 3)  // Peso total calculado dos itens
  freightCost    Decimal?       @db.Decimal(12, 2)
  notes          String?        @db.VarChar(500)
  // Campos de sincronização offline
  syncStatus     SyncStatus     @default(SYNCED)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order          Order          @relation(fields: [orderId], references: [id])
  customer       Customer       @relation(fields: [customerId], references: [id])

  @@index([tenantId, scheduledAt])
  @@map("deliveries")
}

// =============================================================================
// MÓDULO CORE — Estoque
// =============================================================================

/// Movimentação de estoque. Rastreabilidade de entradas e saídas.
model StockMovement {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @db.Uuid
  productId   String          @db.Uuid
  supplierId  String?         @db.Uuid
  type        TransactionType                    // INCOME = entrada, EXPENSE = saída
  quantity    Decimal         @db.Decimal(12, 4)
  unitCost    Decimal?        @db.Decimal(12, 4) // Custo unitário na entrada
  reason      String?         @db.VarChar(150)   // Ex: "Compra NF 1234", "Ajuste de inventário"
  // Campos de sincronização offline
  syncStatus  SyncStatus      @default(SYNCED)
  createdAt   DateTime        @default(now())

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  supplier    Supplier?       @relation(fields: [supplierId], references: [id])

  @@index([tenantId, productId, createdAt])
  @@map("stock_movements")
}

// =============================================================================
// MÓDULO CORE — Auditoria Seletiva
// =============================================================================

/// Auditoria seletiva de eventos críticos (ADR-004)
/// Registra apenas ações sensíveis: cancelamento de venda, alteração de preço,
/// ajuste manual de estoque, fechamento de caixa com divergência, mudança de papel
model AuditEvent {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String?  @db.Uuid              // Usuário que executou a ação (null para ações do sistema)
  entity    String   @db.VarChar(60)       // Ex: "Order", "Product", "CashSession", "User"
  entityId  String   @db.Uuid              // ID da entidade afetada
  action    String   @db.VarChar(60)       // Ex: "CANCEL_ORDER", "CHANGE_PRICE", "ADJUST_STOCK", "CLOSE_CASH_WITH_DIVERGENCE"
  meta      Json?                          // Metadados compactos da ação (valores antes/depois, motivo, etc.)
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_events")
}
